<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body{margin:0;padding:0;background:#06080d;font-family:Arial,sans-serif;color:#e2e8f0}
    .wrap{max-width:520px;margin:40px auto;background:#111827;border:1px solid #1e293b;border-radius:12px;overflow:hidden}
    .header{padding:24px 32px;border-bottom:1px solid #1e293b;background:linear-gradient(135deg,#111827,#162032)}
    .logo{font-size:20px;font-weight:700;color:#f59e0b}
    .body{padding:32px}
    h2{font-size:19px;font-weight:700;margin:0 0 12px}
    p{color:#94a3b8;font-size:14px;line-height:1.6;margin:0 0 12px}
    .alert{background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.3);border-radius:8px;padding:14px;font-size:13.5px;color:#10b981;margin:20px 0}
    .warn{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);border-radius:8px;padding:14px;font-size:13px;color:#fca5a5;margin:14px 0}
    .cta{display:inline-block;background:#f59e0b;color:#000;padding:12px 24px;border-radius:8px;font-weight:700;text-decoration:none;font-size:14px;margin-top:4px}
    .footer{padding:16px 32px;border-top:1px solid #1e293b;text-align:center;font-size:12px;color:#475569}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="header"><div class="logo">☀️ Solar Maket</div></div>
    <div class="body">
      <h2>Password Changed Successfully</h2>
      <p>Hi {{firstName}},</p>
      <div class="alert">✅ Your Solar Maket account password was changed successfully at {{changeTime}}.</div>
      <div class="warn">
        ⚠️ <strong>Wasn't you?</strong> If you did not make this change, your account may be compromised. Contact support immediately.
      </div>
      <p>For your security, all active sessions have been signed out on other devices.</p>
      <a href="{{frontendUrl}}/support" class="cta">Contact Support</a>
    </div>
    <div class="footer">© {{year}} Solar Maket Nigeria Ltd.</div>
  </div>
</body>
</html>
